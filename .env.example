# WISE platform environment — copy to .env and adjust for local development.
# Architecture: docs/architecture/canonical/ (architecture-v1.0)

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
WISE_ENVIRONMENT=development
WISE_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PostgreSQL + PostGIS + pgvector
# -----------------------------------------------------------------------------
POSTGRES_USER=wise
POSTGRES_PASSWORD=wise
POSTGRES_DB=wise
DATABASE_URL=postgresql://wise:wise@postgres:5432/wise

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# MinIO (T0/T1 object storage — 05-physical-architecture §3)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=wise
MINIO_ROOT_PASSWORD=wise-minio-secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=wise-preservation
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# OpenSearch (Phase 6 Search — scaffold only)
# -----------------------------------------------------------------------------
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=WiseOpenSearch1!

# -----------------------------------------------------------------------------
# Service ports (host mapping)
# -----------------------------------------------------------------------------
API_SERVICE_PORT=8000
DISCOVERY_SERVICE_PORT=8001
METADATA_SERVICE_PORT=8002
PRESERVATION_SERVICE_PORT=8003
KNOWLEDGE_GRAPH_SERVICE_PORT=8004

# -----------------------------------------------------------------------------
# Observability (scaffold — 04-system-diagram §2.1)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# ARK namespace (07-reference-standards §3 — assigned at institution registration)
# -----------------------------------------------------------------------------
WISE_ARK_NAAN=99999
