  "pipelines": [
    {
      "pipeline_id": "rc13-articles",
      "name": "Articles",
      "purpose": "Long-form editorial and search-friendly narratives",
      "input_sets": [
        "top_25_showcase_assets",
        "top_25_showcase_collections",
        "top_25_showcase_series",
        "top_25_showcase_products"
      ],
      "stages": [
        "select source asset and related collection",
        "draft educational narrative and source-aware summary",
        "attach rights and image requirements placeholder",
        "generate channel-specific metadata",
        "queue for editorial review before distribution"
      ],
      "outputs": [
        "draft_articles.json",
        "articles_metadata.json"
      ],
      "distribution_targets": [
        "Nature & Culture web",
        "SEO",
        "Pinterest",
        "YouTube",
        "Email newsletter"
      ]
    },
