{
  "reference_capability": "RC13 Publishing & Distribution Platform",
  "authority": "architecture-v1.0, ADR-011",
  "inputs": {
    "top_25_showcase_assets": "data/publishing/top_25_showcase_assets.json",
    "top_25_showcase_collections": "data/portfolio/top_25_showcase_collections.json",
