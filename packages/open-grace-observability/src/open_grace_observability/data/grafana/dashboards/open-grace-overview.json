{
  "uid": "open-grace-overview",
  "title": "Open Grace Observability Overview",
  "tags": ["open-grace", "observability", "v1"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Agent Execution Latency (p50)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(open_grace_agent_execution_latency_seconds_bucket[5m]))",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 2,
      "title": "Capability Success Rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "open_grace_capability_metric_gauge{metric_kind=\"success\"}",
          "legendFormat": "{{capability_id}}"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 3,
      "title": "Benchmark Pass Rate",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "avg(open_grace_benchmark_observed_value{passed=\"true\"})",
          "legendFormat": "pass rate"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 4,
      "title": "Daily Cost (USD)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 8},
      "targets": [
        {
          "expr": "sum by (agent_id) (increase(open_grace_cost_usd_total[24h]))",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 5,
      "title": "Audit Evidence Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "{job=\"open-grace\", component=\"audit\"}",
          "legendFormat": ""
        }
      ],
      "datasource": {"type": "loki", "uid": "loki"}
    }
  ]
}
